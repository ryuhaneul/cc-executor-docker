# API key for authenticating requests (used as Bearer token)
# Generate with: openssl rand -hex 32
CC_API_KEY=your-secret-key-here

# Backend-signed Webductor claim secret. Use a separate random value.
WD_CLAIM_SIGNING_SECRET=replace-with-32-byte-random-secret

# Set true in webductor deployments to disable legacy /v1/* and /admin/*.
CC_DISABLE_LEGACY=false

# Host port (default: 9100)
CC_PORT=9100

# Request timeout in seconds (default: 300)
CC_TIMEOUT=300

# Optional Codex/OpenAI API key fallback. Web apps can use browser login flows;
# headless/test deployments may set this instead.
CODEX_API_KEY=

# Codex default model for model=codex/default
CODEX_DEFAULT_MODEL=gpt-5.5

# Security: danger-full-access is blocked by default. Only enable this for
# trusted, single-user deployments where Codex may access the full container.
CC_CODEX_ALLOW_DANGER_FULL_ACCESS=false

# Web deployments should require each user's Codex/ChatGPT login instead of
# falling back to a shared CODEX_API_KEY.
CC_CODEX_REQUIRE_USER_AUTH=false

# CODEX_ACCESS_TOKEN is not consumed directly from env by this proxy. To use an
# access token, run `codex login --with-access-token` so /root/.codex/auth.json
# exists in the codex-auth volume.
